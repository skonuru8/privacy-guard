{
  "name": "privacy-guard",
  "displayName": "Privacy Guard",
  "description": "AI-powered privacy checks before commits and for your dependencies",
  "version": "0.1.0",
  "publisher": "consenterra",
  "repository": {
    "type": "git",
    "url": "https://github.com/skonuru8/privacy-guard"
  },
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Linters", "Other"],
  "main": "./out/extension.js",
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "commands": [
      {
        "command": "privacyGuard.checkStagedChanges",
        "title": "Privacy Guard: Check Staged Changes (Pre-Commit)"
      },
      {
        "command": "privacyGuard.scanPackages",
        "title": "Privacy Guard: Scan Dependencies"
      },
      {
        "command": "privacyGuard.installHook",
        "title": "Privacy Guard: Install Pre-Commit Hook"
      },
      {
        "command": "privacyGuard.uninstallHook",
        "title": "Privacy Guard: Uninstall Pre-Commit Hook"
      }
    ],
    "configuration": {
      "title": "Privacy Guard",
      "properties": {
        "privacyGuard.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for the selected provider. Anthropic: console.anthropic.com — OpenAI: platform.openai.com — OpenRouter: openrouter.ai/keys"
        },
        "privacyGuard.provider": {
          "type": "string",
          "enum": ["anthropic", "openai", "openrouter"],
          "enumDescriptions": [
            "Anthropic Claude (claude-sonnet-4-20250514)",
            "OpenAI (gpt-4o)",
            "OpenRouter — access hundreds of models with one key"
          ],
          "default": "anthropic",
          "description": "AI provider to use for privacy analysis. Set apiKey to match the chosen provider."
        },
        "privacyGuard.openRouterModel": {
          "type": "string",
          "default": "mistralai/mistral-7b-instruct",
          "description": "Model slug to use when provider is openrouter. See openrouter.ai/models for the full list."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "privacyGuard",
          "title": "Privacy Guard",
          "icon": "$(shield)"
        }
      ]
    },
    "views": {
      "privacyGuard": [
        {
          "type": "webview",
          "id": "privacyGuard.panel",
          "name": "Privacy Guard"
        }
      ]
    },
    "menus": {
      "scm/title": [
        {
          "command": "privacyGuard.checkStagedChanges",
          "group": "privacyGuard"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --skip-license"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.3.0"
  }
}